generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ZoneKind {
  INDOOR
  OUTDOOR
  BONDED
}

/// Quantities for general / breakbulk cargo (no container/TEU assumption).
enum CapacityUnit {
  SQFT
  CUBIC_FT
  PALLET
  METRIC_TON
  PIECE
}

enum ReservationKind {
  HARD
  SOFT
}

enum SpotStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  name         String?
  createdAt    DateTime           @default(now())
  warehouses   PlannerWarehouse[]
}

/// User-defined building / shed for real-time stowage planning (sq ft, slab, clear height).
model PlannerWarehouse {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  /// Total floor area (sq ft) available for planning.
  sqFt             Float
  /// User-reported allowable uniform load (psf). Not a structural sign-off.
  floorStrengthPsf Float
  /// Clear height (ft) to underside of roof or obstructions.
  roofHeightFt     Float
  /// Margin 0–1 applied to structural limits in the planner (default 0.8).
  loadFactor       Float          @default(0.8)
  /// Fraction of floor held back for aisles / handling (default 0.1).
  bufferPct        Float          @default(0.1)
  /// Allowance under roof for sprinklers, lights, lift mast (ft).
  clearanceUnderRoofFt Float      @default(2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cargoLots        PlannerCargoLot[]

  @@index([userId])
}

model PlannerCargoLot {
  id            String           @id @default(cuid())
  warehouseId   String
  warehouse     PlannerWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  label         String
  /// Footprint while in store (sq ft).
  sqFt          Float
  /// Total weight (lb).
  weightLbs     Float
  /// Required vertical clearance for stack / commodity (ft).
  stackHeightFt Float
  startAt       DateTime
  endAt         DateTime
  /// Higher = less likely to be suggested for deferral.
  priority      Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([warehouseId, startAt, endAt])
}

model WarehouseZone {
  id           String   @id @default(cuid())
  name         String
  portLocode   String   @default("USMOB")
  kind         ZoneKind
  totalSqFt    Float
  bufferPct    Float    @default(0.12)
  movesPerDay  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations Reservation[]
  spotRequests SpotRequest[]
}

model Reservation {
  id          String           @id @default(cuid())
  zoneId      String
  zone        WarehouseZone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  customerRef String
  laneRef     String?
  title       String?
  startsAt    DateTime
  endsAt      DateTime
  kind        ReservationKind
  priority    Int              @default(0)
  quantity    Float
  unit        CapacityUnit
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([zoneId, startsAt, endsAt])
}

model ForecastLine {
  id          String       @id @default(cuid())
  customerRef String
  laneRef     String?
  periodStart DateTime
  periodEnd   DateTime
  expectedQty Float
  unit        CapacityUnit
  source      String?
  createdAt   DateTime     @default(now())

  @@index([periodStart, periodEnd])
}

model SpotRequest {
  id                      String           @id @default(cuid())
  zoneId                  String?
  zone                    WarehouseZone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  requesterRef            String
  quantity                Float
  unit                    CapacityUnit
  windowStart             DateTime
  windowEnd               DateTime
  allowPreemptLowPriority Boolean          @default(true)
  status                  SpotStatus       @default(PENDING)
  createdAt               DateTime         @default(now())

  @@index([status, windowStart])
}

model PlanningEvent {
  id        String   @id @default(cuid())
  type      String
  payload   String
  severity  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
