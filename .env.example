# Supabase — Project Settings → API (URL + anon key) and service role (server only, never expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# NextAuth — required for login (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Optional in dev; set in production to your public URL
# AUTH_URL="http://localhost:3000"

# Optional: protect cron endpoint (send as Authorization: Bearer <secret>)
CRON_SECRET="change-me-in-production"

# Replanning: treat vessel ETA changes over this many hours as significant
PLANNING_ETA_SHIFT_HOURS="24"

# NOAA NWS marine zone IDs (comma-separated). Adjust for your operating areas.
# See https://www.weather.gov/marine/ — examples near Gulf / Mississippi Sound.
NWS_MARINE_ZONES="GMZ335,GMZ532"

# Commercial AIS / vessel API (provider-specific; wire URL in integrations when subscribed)
AIS_API_URL=""
AIS_API_KEY=""
